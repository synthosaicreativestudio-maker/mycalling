generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  PARENT
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
}

model User {
  id            String              @id @default(dbgenerated("gen_random_uuid()")) @map("user_id") @db.Uuid
  name          String              @map("username") @db.VarChar(100)
  fullName      String?             @map("full_name") @db.VarChar(100)
  email         String              @unique
  emailVerified Boolean             @default(false) @map("email_verified")
  image         String?
  grade         Int?
  phone         String?             @unique
  telegramId    String?             @unique @map("telegram_id")
  maxUserId     String?             @unique @map("max_user_id")
  role          Role                @default(STUDENT)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  sessions      Session[]
  accounts      Account[]
  
  // Новые отношения
  coachSession  CoachSession?
  diagnostics   DiagnosticResult[]
  profile       DigitalProfile?
  report        Report?

  // Отношение Родитель-Ребенок
  childId       String?             @map("child_id") @db.Uuid
  child         User?               @relation("ParentChild", fields: [childId], references: [id])
  parents       User[]              @relation("ParentChild")

  @@map("users")
}

model Session {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id") @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("account")
}

model Verification {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier String
  value      String
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("verification")
}

model CoachSession {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String         @unique @map("user_id") @db.Uuid
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  status        SessionStatus  @default(IN_PROGRESS)
  transcript    Json           // полная история диалога (массив сообщений)
  extractedData Json           // структурированные качественные данные
  completedAt   DateTime?      @map("completed_at") @db.Timestamptz(6)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("coach_sessions")
}

model DiagnosticResult {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  testCode      String   @map("test_code") // "RIASEC" | "BFI" | "ICAR" | "PROCRASTINATION"
  rawResponses  Json     @map("raw_responses")
  scores        Json     // { R: 12, I: 8, ... }
  reliability   String   // "high" | "medium" | "low"
  completedAt   DateTime @default(now()) @map("completed_at") @db.Timestamptz(6)

  @@map("diagnostic_results")
}

model DigitalProfile {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary     Json     // объединённые данные коуча + тестов
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("digital_profiles")
}

model Report {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @unique @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  htmlContent String   @map("html_content")
  pdfUrl      String?  @map("pdf_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("reports")
}
