DATABASE_URL="postgresql://user:password@host:port/dbname?pgbouncer=true"
DIRECT_URL="postgresql://user:password@host:port/dbname"
PROXYAPI_KEY="your_proxyapi_key_here"
# Быстрая модель для экстракции реплик коуча (ускоряет ответы). Пусто = основная
# модель. Укажите лёгкую модель из вашего тарифа ProxyAPI, например:
# EXTRACTION_MODEL="gpt-5-mini"
EXTRACTION_MODEL=""

# Sentry (docs/18 P3.1) — без этих переменных SDK инициализируется в
# выключенном состоянии (enabled: false), сборка не падает.
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""
# Нужны только для загрузки sourcemaps при билде (необязательно локально):
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# Т-Банк (Тинькофф) Интернет-эквайринг / Биллинг
# ВАЖНО: если пароль/ключ содержит символ '$', в .env экранируйте его как '\$'.
# Иначе Next.js (dotenv-expand) воспримет '$XXX' как подстановку переменной и
# обрежет секрет — подпись Token станет неверной (ошибка 204 на GetState/GetQr).
# В хостинге (Vercel и т.п.) переменные задаются как есть, без экранирования.
TINKOFF_TERMINAL_KEY="your_terminal_key_here"
TINKOFF_SECRET_KEY="your_secret_key_here"
TINKOFF_PASSWORD="your_terminal_password_here"

